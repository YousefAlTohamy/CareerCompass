!models/.gitkeep

# ── Test / Scratch Files ─────────────────────────────────────────────
test.pdf
*.pdf
*.docx
*.png
*.jpg

# ── Environment Variables ────────────────────────────────────────────
.env
.env.*

# ── OS / Editor Junk ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Build / Dist ─────────────────────────────────────────────────────
dist/
build/
*.egg-info/

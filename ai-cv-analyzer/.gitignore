# ── Virtual Environment ──────────────────────────────────────────────
venv/
.venv/
env/

# ── Python Cache ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── Jupyter Notebooks ────────────────────────────────────────────────
.ipynb_checkpoints/

# ── ML Model Weights (large binary files — download via HuggingFace) ─
models/ner_weights/
models/sent_bert/
models/class_weights/
